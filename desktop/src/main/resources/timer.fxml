<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="768" prefWidth="1024" style="-fx-background-color: #F8F9FA;" xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hackathon.controllers.TimerController">

    <HBox alignment="CENTER_LEFT" spacing="12"
          style="-fx-background-color: #FFFFFF; -fx-padding: 10 24; -fx-border-color: transparent transparent #DEE2E6 transparent; -fx-border-width: 0 0 1 0;">
        <ImageView fitHeight="36" preserveRatio="true" pickOnBounds="true">
            <Image url="@HacStationLogo.png"/>
        </ImageView>
        <Label style="-fx-text-fill: #212529; -fx-font-family: 'Plus Jakarta Sans', sans-serif; -fx-font-weight: 700;" text="HackStation">
            <font>
                <Font name="System Bold" size="18"/>
            </font>
        </Label>
        <Region HBox.hgrow="ALWAYS"/>
        <Button mnemonicParsing="false" onAction="#goToDashboard"
                style="-fx-background-color: #FFFFFF; -fx-text-fill: #212529; -fx-border-color: #DEE2E6; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 6 14; -fx-font-size: 13px;"
                text="Dashboard"/>
        <Button mnemonicParsing="false" onAction="#goToChat"
                style="-fx-background-color: #228BE6; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 6 14; -fx-font-size: 13px;"
                text="Chat"/>
    </HBox>

    <VBox alignment="CENTER" spacing="24" VBox.vgrow="ALWAYS">
        <padding>
            <Insets bottom="40" left="40" right="40" top="24"/>
        </padding>

        <Label style="-fx-text-fill: #212529; -fx-font-family: 'Plus Jakarta Sans', sans-serif;" text="Hackathon Timer">
            <font>
                <Font name="System Bold" size="28"/>
            </font>
        </Label>

        <Label fx:id="timerDisplay" alignment="CENTER" style="-fx-text-fill: #212529;" text="00:00:00"
               textAlignment="CENTER">
            <font>
                <Font name="System Bold" size="72"/>
            </font>
        </Label>

        <ProgressBar fx:id="phaseProgress" prefWidth="600" progress="0.0"
                     style="-fx-accent: #228BE6;"/>

        <Label style="-fx-text-fill: #868E96; -fx-font-size: 13px;" text="Phase Progress"/>

        <VBox fx:id="phaseList" spacing="6"
              style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-padding: 20; -fx-border-color: #DEE2E6; -fx-border-radius: 12;">
            <padding>
                <Insets left="16" right="16" top="8" bottom="8"/>
            </padding>
        </VBox>

        <HBox alignment="CENTER" spacing="16">
            <Button fx:id="startPauseButton" mnemonicParsing="false" onAction="#handleStartPause"
                    prefWidth="120"
                    style="-fx-background-color: #228BE6; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 12; -fx-font-size: 14px;"
                    text="Start"/>
            <Button fx:id="resetButton" mnemonicParsing="false" onAction="#handleReset"
                    prefWidth="120"
                    style="-fx-background-color: #FFFFFF; -fx-text-fill: #212529; -fx-border-color: #DEE2E6; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 12; -fx-font-size: 14px;"
                    text="Reset"/>
        </HBox>
    </VBox>
</VBox>
