<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="768" prefWidth="1024" style="-fx-background-color: #0f0f23;" xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hackathon.controllers.ChatController">

    <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: #1a1a2e; -fx-padding: 16 24;">
        <Label style="-fx-text-fill: #e94560;" text="HackStation" textFill="WHITE">
            <font>
                <Font name="System Bold" size="20"/>
            </font>
        </Label>
        <Region HBox.hgrow="ALWAYS"/>
        <Button mnemonicParsing="false" onAction="#goToDashboard"
                style="-fx-background-color: #16213e; -fx-text-fill: white;" text="Dashboard"/>
    </HBox>

    <VBox spacing="12" VBox.vgrow="ALWAYS">
        <padding>
            <Insets bottom="12" left="24" right="24" top="12"/>
        </padding>

        <Label style="-fx-text-fill: white;" text="Chat">
            <font>
                <Font name="System Bold" size="28"/>
            </font>
        </Label>

        <TabPane style="-fx-background-color: #1a1a2e;" tabClosingPolicy="UNAVAILABLE">
            <Tab fx:id="communityTab" text="Community"/>
            <Tab fx:id="teamTab" text="Team"/>
        </TabPane>

        <ListView fx:id="messageList" prefHeight="Infinity"
                  style="-fx-background-color: #16213e; -fx-control-inner-background: #16213e; -fx-text-fill: white;"
                  VBox.vgrow="ALWAYS"/>

        <HBox spacing="8">
            <TextField fx:id="messageInput" promptText="Type a message..."
                       style="-fx-background-radius: 8; -fx-padding: 10;" HBox.hgrow="ALWAYS"/>
            <Button mnemonicParsing="false" onAction="#handleSendButton"
                    style="-fx-background-color: #e94560; -fx-text-fill: white; -fx-background-radius: 8;"
                    text="Send"/>
        </HBox>
    </VBox>
</VBox>
