<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="768" prefWidth="1024" style="-fx-background-color: #F8F9FA;" xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hackathon.controllers.DashboardController">

    <HBox alignment="CENTER_LEFT" spacing="12"
          style="-fx-background-color: #FFFFFF; -fx-padding: 10 24; -fx-border-color: transparent transparent #DEE2E6 transparent; -fx-border-width: 0 0 1 0;">
        <ImageView fitHeight="36" preserveRatio="true" pickOnBounds="true">
            <Image url="@HacStationLogo.png"/>
        </ImageView>
        <Label style="-fx-text-fill: #212529; -fx-font-family: 'Plus Jakarta Sans', sans-serif; -fx-font-weight: 700;" text="HackStation">
            <font>
                <Font name="System Bold" size="18"/>
            </font>
        </Label>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="userNameLabel" style="-fx-text-fill: #495057; -fx-font-size: 13px;" text="User"/>
        <Button mnemonicParsing="false" onAction="#openTimer"
                style="-fx-background-color: #FFFFFF; -fx-text-fill: #212529; -fx-border-color: #DEE2E6; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 6 14; -fx-font-size: 13px;"
                text="Timer"/>
        <Button mnemonicParsing="false" onAction="#openChat"
                style="-fx-background-color: #228BE6; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 6 14; -fx-font-size: 13px;"
                text="Chat"/>
    </HBox>

    <VBox spacing="24" VBox.vgrow="ALWAYS">
        <padding>
            <Insets bottom="32" left="32" right="32" top="32"/>
        </padding>

        <Label style="-fx-text-fill: #212529; -fx-font-family: 'Plus Jakarta Sans', sans-serif;" text="Dashboard">
            <font>
                <Font name="System Bold" size="28"/>
            </font>
        </Label>
        <Label style="-fx-text-fill: #868E96; -fx-font-size: 13px;" text="Event overview at a glance"/>

        <GridPane hgap="16" vgap="16">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="200" percentWidth="50"/>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="200" percentWidth="50"/>
            </columnConstraints>
            <VBox spacing="8"
                  style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-padding: 24; -fx-border-color: #DEE2E6; -fx-border-radius: 12;">
                <Label style="-fx-text-fill: #495057;" text="Timer">
                    <font>
                        <Font name="System Bold" size="18"/>
                    </font>
                </Label>
                <Label fx:id="timerDisplay" style="-fx-text-fill: #212529;" text="00:00:00">
                    <font>
                        <Font size="36"/>
                    </font>
                </Label>
            </VBox>
            <VBox spacing="8"
                  style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-padding: 24; -fx-border-color: #DEE2E6; -fx-border-radius: 12;"
                  GridPane.columnIndex="1">
                <Label style="-fx-text-fill: #495057;" text="Quick Stats">
                    <font>
                        <Font name="System Bold" size="18"/>
                    </font>
                </Label>
                <Label fx:id="statsHackathons" style="-fx-text-fill: #228BE6;" text="Active: 0"/>
                <Label fx:id="statsTeam" style="-fx-text-fill: #228BE6;" text="Team: 0"/>
            </VBox>
        </GridPane>

        <VBox spacing="8" VBox.vgrow="ALWAYS">
            <Label style="-fx-text-fill: #212529;" text="Announcements">
                <font>
                    <Font name="System Bold" size="18"/>
                </font>
            </Label>
            <VBox fx:id="announcementsList" spacing="6"
                  style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-padding: 20; -fx-border-color: #DEE2E6; -fx-border-radius: 12;"/>
        </VBox>
    </VBox>
</VBox>
